# Copy to .env for local development. NEVER commit real secrets (CLAUDE.md §2/§3.20).
NODE_ENV=development
PORT=3000

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://agentos:agentos@localhost:5432/agentos

# Redis (matches docker-compose.yml)
REDIS_URL=redis://localhost:6379

# RLS-scoped Postgres roles (db/policies/000-roles.sql) — local dev only, never reuse in
# a real environment (CLAUDE.md §2: secrets belong in a managed secret manager there).
APP_USER_DB_PASSWORD=app_user
PLATFORM_OPERATOR_DB_PASSWORD=platform_operator

# Logging
LOG_LEVEL=info

# OpenTelemetry — tracing is a no-op unless an OTLP endpoint is configured.
OTEL_SERVICE_NAME=agentos-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- Auth / access tokens (Phase 2) ---
# Ed25519 access-token signing keys (PEM). Leave unset in dev/test to auto-generate an
# ephemeral keypair at boot; REQUIRED in production (inject from a secret manager, never commit).
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_KID=dev
JWT_ISSUER=agentos
JWT_AUDIENCE=agentos-api
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Argon2id (OWASP defaults)
ARGON2_MEMORY_KIB=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# Login brute-force throttle (Redis-backed)
LOGIN_MAX_ATTEMPTS=10
LOGIN_LOCKOUT_SECONDS=900

# Refresh-token cookie (browser clients)
AUTH_COOKIE_NAME=agentos_refresh
AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_DOMAIN=localhost
